# =============================================================
# Mavuno — Environment Variables Template
# =============================================================
# Copy to `.env` (never commit real values).
# In production set these via the Vercel Project Settings UI or
#   `vercel env add NAME production`.
# =============================================================

# Required: HMAC secret used to sign session cookies and ECT tokens.
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
HMAC_SECRET=change-me-please-generate-a-long-random-string

# Required for production: public URL of the deployed app.
PUBLIC_BASE_URL=https://mavuno-prototype.vercel.app

# Optional: Africa's Talking USSD sandbox credentials.
AT_USERNAME=sandbox
AT_API_KEY=

# Optional: Groq API key — enables the live AI agronomist.
# Without this the advisor falls back to a deterministic rule bank,
# so demos never go silent. Sign up at https://console.groq.com.
GROQ_API_KEY=
